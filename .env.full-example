CHAT_PROVIDER=OPENAI
IMAGE_PROVIDER=OPENAI
SPEECH_PROVIDER=OPENAI
TRANSCRIPTION_PROVIDER=OPENAI

### PROVIDERS CONFIG (APIKEY, BASEURL)

# OPENAI CONFIGURATION
OPENAI_API_KEY=your_openai_api_key
OPENAI_COMPLETION_MODEL=gpt-5-mini
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_SPEECH_MODEL=gpt-4o-mini-tts
OPENAI_SPEECH_VOICE=nova
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe

# CLAUDE CONFIGURATION
CLAUDE_API_KEY=your_claude_api_key
CLAUDE_CHAT_MODEL=claude-sonnet-4-20250514

# DEEPSEEK CONFIGURATION
DEEPSEEK_API_KEY=your_api_key
DEEPSEEK_COMPLETION_MODEL=deepseek-chat

# QWEN CONFIGURATION
QWEN_API_KEY=your_api_key
QWEN_COMPLETION_MODEL=qwen2.5-vl-72b-instruct

# DEEPINFRA CONFIGURATION
DEEPINFRA_API_KEY=your_api_key
DEEPINFRA_BASEURL=https://api.deepinfra.com/v1/openai
DEEPINFRA_COMPLETION_MODEL=openai/gpt-oss-120b
DEEPINFRA_IMAGE_CREATION_MODEL=stabilityai/sd3.5
DEEPINFRA_TRANSCRIPTION_MODEL=deepinfra-chat

## ELEVENLABS CONFIG
ELEVENLABS_API_KEY=your_api_key
ELEVENLABS_VOICEID=EXAVITQu4vr4xnSDxMaL
ELEVENLABS_SPEECH_MODEL='eleven_multilingual_v2'

# CUSTOM AI CONFIGURATION (This might not always work. It is just for testing purposes.)
CUSTOM_API_KEY=your_api_key
CUSTOM_BASEURL=https://ai.aiprovider.com/v1
CUSTOM_COMPLETION_MODEL=custom-model1.0

# BOT CONFIGURATION
PREFERRED_LANGUAGE=english
MAX_CHARACTERS=2000
BOT_NAME=Roboto
MAX_IMAGES=3
MAX_MSGS_LIMIT=30
MAX_HOURS_LIMIT=24
NODE_CACHE_TIME=259200
# MESSAGE_CACHE_TTL=300    # Override per-chat message cache TTL in seconds (0 = use NODE_CACHE_TIME)
# MEDIA_CACHE_TTL=86400    # Override downloaded media cache TTL in seconds
# TRANSCRIPTION_CACHE_TTL=86400  # Override transcribed voice cache TTL in seconds
# RATE_LIMIT_MAX=30        # Max AI requests per window per chat/author. 0 = disabled.
# RATE_LIMIT_WINDOW_SEC=60 # Sliding window for rate limiting in seconds. Default: 60.
TRANSCRIPTION_LANGUAGE=en
MAX_IMAGE_SIZEMB=10
MAX_DOCUMENT_SIZEMB=20
USE_CONTACT_NAMES=true
MEMORIES_ENABLED=true

# Whether to enable OpenAI server-side storage of conversations. Default: false.
# Set to true to allow OpenAI to retain conversations on their servers (previous default behavior).
OPENAI_STORE=false

# Maximum tokens for Claude completions. Default: 2048.
CLAUDE_MAX_TOKENS=2048

# Whether to run Puppeteer with --no-sandbox. Required in some Docker/CI environments. Default: false.
PUPPETEER_NO_SANDBOX=false

# Additional prompt info to tailor the bot's personality (optional)
PROMPT_INFO="You should adopt a friendly and informal tone, often using emojis in responses"

# FEATURE TOGGLES
IMAGE_CREATION_ENABLED=false
VOICE_MESSAGES_ENABLED=false

LOG_LEVEL=debug
ADMIN_NUMBERS=14255550126
