#PROVIDERS
CHAT_PROVIDER=OPENAI

## OPENAI CONFIG
OPENAI_API_KEY=your_api_key
OPENAI_COMPLETION_MODEL=gpt-5-mini
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe
OPENAI_SPEECH_MODEL=gpt-4o-mini-tts
OPENAI_SPEECH_VOICE=nova

## BOT CONFIG
PREFERRED_LANGUAGE=
BOT_NAME=Roboto
TRANSCRIPTION_LANGUAGE=en
USE_CONTACT_NAMES=true
MEMORIES_ENABLED=true
OPENAI_STORE=false
# CLAUDE_MAX_TOKENS=2048   # Maximum tokens for Claude completions. Default: 2048.
PUPPETEER_NO_SANDBOX=false
# MESSAGE_CACHE_TTL=300    # Per-chat message cache TTL in seconds (0 = use NODE_CACHE_TIME default 3 days)
# MEDIA_CACHE_TTL=86400    # Downloaded media cache TTL in seconds (0 = use NODE_CACHE_TIME)
# TRANSCRIPTION_CACHE_TTL=86400  # Transcribed voice cache TTL in seconds (0 = use NODE_CACHE_TIME)
# RATE_LIMIT_MAX=30        # Max AI requests per window per chat/author. 0 = disabled.
# RATE_LIMIT_WINDOW_SEC=60 # Sliding window for rate limiting in seconds. Default: 60.

## CONNECTION WATCHDOG
# WATCHDOG_ENABLED=false       # Enable/disable periodic connection probe + auto-reconnect. Default: true.
# WATCHDOG_INTERVAL_SEC=30     # Seconds between connection probes (min 10, max 300). Default: 30.
# RECONNECT_BASE_DELAY_SEC=5   # Base delay for exponential backoff in seconds (min 1). Default: 5.
# RECONNECT_MAX_DELAY_SEC=300  # Maximum backoff delay cap in seconds (min 5, max 3600). Default: 300.
# RECONNECT_MAX_ATTEMPTS=3     # Max reconnect attempts before process.exit(1). 0 = infinite (default).

## FEATURES
IMAGE_CREATION_ENABLED=true
VOICE_MESSAGES_ENABLED=true

# You can use this to customize the default bot's personality and information (Or it can be customized using -chatconfig)
PROMPT_INFO="You are a friendly and informal assistant"
